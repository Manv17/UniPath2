<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ButtonBar?>
<?import javafx.scene.control.ChoiceBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="300.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.unipath2.ui.controllers.windows.edits.EditAptitudinalController">
   <children>
      <VBox maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="350.0" prefWidth="600.0" spacing="30.0" style="-fx-background-color: fff;" stylesheets="@../../styles/button-style.css">
         <children>
            <Label fx:id="nameLabel" contentDisplay="CENTER" graphicTextGap="10.0" prefWidth="700.0" styleClass="title" text="Name">
               <font>
                  <Font name="SF Pro Italic" size="36.0" />
               </font>
            </Label>
            <HBox maxWidth="-Infinity" prefHeight="140.0" prefWidth="550.0" spacing="60.0">
               <children>
                  <HBox>
                     <children>
                        <VBox maxWidth="1.7976931348623157E308" spacing="10.0">
                           <children>
                              <Label text="Stato:">
                                 <font>
                                    <Font size="18.0" />
                                 </font>
                              </Label>
                              <ChoiceBox fx:id="statusChoice" prefHeight="30.0" prefWidth="150.0" />
                           </children>
                        </VBox>
                     </children>
                  </HBox>
                  <VBox maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" spacing="10.0">
                     <children>
                        <Label text="Data:">
                           <font>
                              <Font size="18.0" />
                           </font>
                        </Label>
                        <DatePicker fx:id="datePicker" />
                        <Button mnemonicParsing="false" onAction="#clearDate" styleClass="clear-button" stylesheets="@../../styles/button-style.css" text="Cancella data" underline="true" />
                     </children>
                  </VBox>
               </children>
            </HBox>
            <ButtonBar maxHeight="1.7976931348623157E308" prefHeight="40.0" prefWidth="200.0">
              <buttons>
                <Button mnemonicParsing="false" onAction="#handleUndoButton" text="Annulla" />
                  <Button mnemonicParsing="false" onAction="#handleEditButton" text="Modifica" />
              </buttons>
               <padding>
                  <Insets top="10.0" />
               </padding>
            </ButtonBar>
         </children>
         <padding>
            <Insets bottom="30.0" left="40.0" right="40.0" top="40.0" />
         </padding>
      </VBox>
   </children>
</AnchorPane>
